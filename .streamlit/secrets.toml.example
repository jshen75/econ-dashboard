# Copy this file to `.streamlit/secrets.toml` and fill in your key.
# Get a free FRED API key: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY = 

# Some .gov APIs want a contact email in the User-Agent. Optional but polite.
# (Also settable via the ECON_CONTACT_EMAIL environment variable.)
# ECON_CONTACT_EMAIL =

# Admin password — gates the Refresh button and the manual-entry forms.
# Set this on a PUBLIC deploy so visitors get a read-only dashboard.
# Leave it unset locally to keep full access.
# ADMIN_PASSWORD = "choose-a-strong-password"

# Optional: durable hosted Postgres, e.g. Neon.
# Paste Neon's pooled or direct connection string here on Streamlit Cloud.
# DATABASE_URL = "postgresql://user:password@host/dbname?sslmode=require"
